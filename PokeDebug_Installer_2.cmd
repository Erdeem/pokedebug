@echo off
setlocal EnableExtensions DisableDelayedExpansion
set "POKEDEBUG_SELF=%~f0"
if /I not "%~1"=="__POKEDEBUG_CONHOST__" (
  start "" "%SystemRoot%\System32\conhost.exe" "%SystemRoot%\System32\cmd.exe" /k "%~s0" __POKEDEBUG_CONHOST__ %*
  exit /b
)
shift
set "POKEDEBUG_WORK=%TEMP%\PokeDebug_%RANDOM%_%RANDOM%_%RANDOM%"
color 07
title  PokeDebug Installer 3.1
mode con: cols=76 lines=34
cd /d "%~dp0"
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Stop';$root=$env:POKEDEBUG_WORK;$self=$env:POKEDEBUG_SELF;$expected='2940762123bd745c90cb02ec5f297b91f7978a8578dda1369652c1c87862fa86';$min=1024;$max=52428800;try{$lines=[IO.File]::ReadAllLines($self,[Text.Encoding]::ASCII);$marker='__POKEDEBUG_PAYLOAD_BELOW__';$hits=@();for($i=0;$i-lt$lines.Length;$i++){if($lines[$i]-eq$marker){$hits+=$i}};if($hits.Count-ne 1){throw 'Invalid payload marker count.'};$payload=($lines[($hits[0]+1)..($lines.Length-1)]-join'');if($payload.Length-lt$min-or$payload.Length-gt$max){throw 'Invalid payload size.'};$packed=[Convert]::FromBase64String($payload);$input=New-Object IO.MemoryStream(,$packed);$output=New-Object IO.MemoryStream;$gzip=New-Object IO.Compression.GZipStream($input,[IO.Compression.CompressionMode]::Decompress);$gzip.CopyTo($output);$gzip.Dispose();$input.Dispose();$zip=$output.ToArray();$output.Dispose();$sha=[Security.Cryptography.SHA256]::Create();$actual=[BitConverter]::ToString($sha.ComputeHash($zip)).Replace('-','').ToLowerInvariant();$sha.Dispose();if($actual-ne$expected){throw 'Payload SHA-256 mismatch.'};[IO.Directory]::CreateDirectory($root)|Out-Null;$acl=New-Object Security.AccessControl.DirectorySecurity;$acl.SetAccessRuleProtection($true,$false);$id=[Security.Principal.WindowsIdentity]::GetCurrent().Name;$rule=New-Object Security.AccessControl.FileSystemAccessRule($id,'FullControl','ContainerInherit,ObjectInherit','None','Allow');$acl.AddAccessRule($rule);[IO.Directory]::SetAccessControl($root,$acl);$zipPath=Join-Path $root 'bundle.zip';[IO.File]::WriteAllBytes($zipPath,$zip);Expand-Archive -LiteralPath $zipPath -DestinationPath (Join-Path $root 'bundle') -Force}catch{Write-Host ('[ERROR] '+$_.Exception.Message) -ForegroundColor Red;exit 1}"
if errorlevel 1 goto :failed
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "%POKEDEBUG_WORK%\bundle\Install.ps1" %*
set "POKEDEBUG_EXIT=%ERRORLEVEL%"
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Remove-Item -LiteralPath $env:POKEDEBUG_WORK -Recurse -Force -ErrorAction SilentlyContinue"
exit /b %POKEDEBUG_EXIT%
:failed
set "POKEDEBUG_EXIT=%ERRORLEVEL%"
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Remove-Item -LiteralPath $env:POKEDEBUG_WORK -Recurse -Force -ErrorAction SilentlyContinue"
pause
exit /b %POKEDEBUG_EXIT%
